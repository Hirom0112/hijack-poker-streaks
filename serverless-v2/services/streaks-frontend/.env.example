# Streaks dashboard local config — copy to `.env`.
# Backend base URL (RTK Query prepends /api/v1/player/streaks).
VITE_API_URL=http://localhost:5001
# Optional: pin the INITIAL calendar month (YYYY-MM). Leave empty to open on the
# current UTC month — the seed anchors the demo data to "today". The arrows page
# back up to 90 days regardless.
VITE_DEMO_MONTH=
